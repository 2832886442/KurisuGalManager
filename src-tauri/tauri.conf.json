{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "KurisuGal",
  "version": "1.2.5",
  "identifier": "com.dleastzh.kurisugal",
  "build": {
    "frontendDist": "../src"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "KurisuGal",
        "width": 1280,
        "height": 720
      }
    ],
    "security": {
      "csp": "default-src 'self' tauri: asset: http: https:; script-src 'self' 'unsafe-inline'; style-src 'unsafe-inline' 'self'; img-src 'self' tauri: asset: data: file: http: https:;"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.ico",
      "icons/48x48.ico",
      "icons/64x64.ico",
      "icons/128x128.ico",
      "icons/256x256.ico"
    ]
  }
}