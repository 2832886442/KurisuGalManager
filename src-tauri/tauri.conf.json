{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "CleanGal",
  "version": "1.2.4",
  "identifier": "com.dleastzh.galmanager",
  "build": {
    "frontendDist": "../src"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "CleanGal",
        "width": 1280,
        "height": 720
      }
    ],
    "security": {
      "csp": "default-src 'self' tauri: asset: http: https:; script-src 'self' 'unsafe-inline'; style-src 'unsafe-inline' 'self'; img-src 'self' tauri: asset: data: file: http: https:;"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}